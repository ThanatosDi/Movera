# 應用程式運行環境 (development | production)
ENV=development

# 允許目錄選擇器瀏覽的根目錄路徑（逗號分隔的絕對路徑）
# ALLOWED_DIRECTORIES=/downloads,/media

# 允許作為檔案來源的目錄路徑（逗號分隔的絕對路徑）
# Webhook 傳入的檔案路徑必須在此白名單範圍內才會被處理
# ALLOWED_SOURCE_DIRECTORIES=/downloads

# 是否允許透過 Web UI 新增/修改目錄設定（true | false，預設 true）
# 設為 false 時，目錄設定僅能透過環境變數管理
# ALLOW_WEBUI_SETTING=true
